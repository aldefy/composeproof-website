---
const tokenRows = [
  { tool: 'insights', desc: 'project overview', input: '~200', output: '~500' },
  { tool: 'list_previews', desc: 'discover 4 @Preview', input: '~200', output: '~300' },
  { tool: 'take_device_screenshot', desc: 'before', input: '~200', output: '~800' },
  { tool: 'device_interact', desc: 'swipe drag', input: '~300', output: '~800' },
  { tool: 'take_device_screenshot', desc: 'after', input: '~200', output: '~800' },
  { tool: 'get_context', desc: 'scope=structure', input: '~200', output: '~2,000' },
  { tool: 'generate_report', desc: '', input: '~300', output: '~500' },
];
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="text-center mb-16">
      <div class="mono-label mb-4">live readout</div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-ink">
        See it in <span class="marker-static">action</span>
      </h2>
      <p class="text-lg text-dim max-w-2xl mx-auto">
        A real session testing StickerExplode — a Compose Multiplatform sticker canvas app.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">

      <!-- Left: HTML Report Preview -->
      <div>
        <h3 class="text-xl font-semibold mb-4 text-ink">Generated Health Report</h3>
        <div class="relative rounded-xl bg-surface overflow-hidden" style="border:1px solid var(--line-2)">
          <div class="corner-tr"></div><div class="corner-bl"></div>
          <!-- Report chrome -->
          <div class="flex items-center justify-between px-4 py-2.5" style="border-bottom:1px solid var(--line-2)">
            <span class="mono-label" style="color:var(--ink-faint)">composeproof-report.html</span>
            <span class="mono-label" style="color:var(--ok)">● generated</span>
          </div>
          <!-- Report body -->
          <div class="p-6 space-y-5">
            <!-- Score header -->
            <div class="flex items-center justify-between">
              <div>
                <div class="mono-label mb-1" style="color:var(--ink-faint)">Project Health</div>
                <div class="text-3xl font-bold text-accent">87<span class="text-lg text-dim">/100</span></div>
              </div>
              <div class="text-right">
                <div class="text-xs text-faint font-mono">StickerExplode</div>
                <div class="text-xs text-faint font-mono">4 assertions &middot; 0 failed</div>
              </div>
            </div>

            <!-- Assertion results -->
            <div class="space-y-2">
              <div class="flex items-center gap-2 text-xs font-mono">
                <span style="color:var(--ok)">PASS</span>
                <span class="text-dim">Has @Preview functions (found 4)</span>
              </div>
              <div class="flex items-center gap-2 text-xs font-mono">
                <span style="color:var(--ok)">PASS</span>
                <span class="text-dim">Compose dependencies present</span>
              </div>
              <div class="flex items-center gap-2 text-xs font-mono">
                <span style="color:var(--ok)">PASS</span>
                <span class="text-dim">Kotlin Multiplatform configured</span>
              </div>
              <div class="flex items-center gap-2 text-xs font-mono">
                <span style="color:var(--ok)">PASS</span>
                <span class="text-dim">Golden baseline coverage &gt; 0%</span>
              </div>
            </div>

            <!-- Compose Intelligence snippet -->
            <div class="pt-4" style="border-top:1px solid var(--line-2)">
              <div class="mono-label mb-2" style="color:var(--ink-faint)">Compose Intelligence</div>
              <div class="grid grid-cols-2 gap-3 text-xs">
                <div class="rounded-lg p-3 bg-page" style="border:1px solid var(--line-2)">
                  <div class="text-faint font-mono">Kotlin Files</div>
                  <div class="text-lg font-semibold text-accent">24</div>
                </div>
                <div class="rounded-lg p-3 bg-page" style="border:1px solid var(--line-2)">
                  <div class="text-faint font-mono">Lines of Code</div>
                  <div class="text-lg font-semibold text-accent">1,847</div>
                </div>
                <div class="rounded-lg p-3 bg-page" style="border:1px solid var(--line-2)">
                  <div class="text-faint font-mono">@Preview</div>
                  <div class="text-lg font-semibold text-accent">4</div>
                </div>
                <div class="rounded-lg p-3 bg-page" style="border:1px solid var(--line-2)">
                  <div class="text-faint font-mono">Sticker Types</div>
                  <div class="text-lg font-semibold text-accent">12</div>
                </div>
              </div>
            </div>

            <!-- Context graph hint -->
            <div class="pt-4" style="border-top:1px solid var(--line-2)">
              <div class="mono-label mb-2" style="color:var(--ink-faint)">Context Graph</div>
              <div class="font-mono text-xs text-dim leading-relaxed">
                <div><span class="text-accent">composeApp</span> <span class="text-faint">→</span> commonMain, androidMain, desktopMain, wasmJsMain</div>
                <div class="mt-1"><span class="text-accent">StickerCanvas.kt</span> <span class="text-faint">→</span> StickerData, StickerType, DragState</div>
                <div class="mt-1 text-faint">+ 22 more files...</div>
              </div>
            </div>
          </div>
        </div>
        <p class="text-dim text-sm mt-4">
          One command generates a self-contained HTML report — assertions, screenshots, compose intelligence, and context graph. Share it, archive it, diff it.
        </p>
      </div>

      <!-- Right: Token Usage -->
      <div>
        <h3 class="text-xl font-semibold mb-4 text-ink">Token Cost</h3>
        <div class="relative rounded-xl bg-surface overflow-hidden" style="border:1px solid var(--line-2)">
          <div class="corner-tr"></div><div class="corner-bl"></div>
          <!-- Table chrome -->
          <div class="flex items-center justify-between px-4 py-2.5" style="border-bottom:1px solid var(--line-2)">
            <span class="mono-label" style="color:var(--ink-faint)">token usage estimate</span>
            <span class="mono-label" style="color:var(--ok)">● measured</span>
          </div>
          <div class="p-5">
            <table class="w-full text-xs font-mono">
              <thead>
                <tr class="text-faint text-left">
                  <th class="pb-3 font-medium">MCP Tool Call</th>
                  <th class="pb-3 font-medium text-right">Input</th>
                  <th class="pb-3 font-medium text-right">Output</th>
                </tr>
              </thead>
              <tbody class="text-dim">
                {tokenRows.map((row) => (
                  <tr style="border-top:1px solid var(--line-2)">
                    <td class="py-2.5">
                      <span class="text-ink">{row.tool}</span>
                      {row.desc && <span class="text-faint"> ({row.desc})</span>}
                    </td>
                    <td class="py-2.5 text-right text-accent">{row.input}</td>
                    <td class="py-2.5 text-right text-accent">{row.output}</td>
                  </tr>
                ))}
              </tbody>
              <tfoot>
                <tr style="border-top:1.5px solid var(--line-2)">
                  <td class="pt-3 text-ink font-semibold">Total</td>
                  <td class="pt-3 text-right text-ink">~1,600</td>
                  <td class="pt-3 text-right text-ink">~5,700</td>
                </tr>
                <tr>
                  <td class="pt-2 text-accent font-semibold" colspan="2">Grand total</td>
                  <td class="pt-2 text-right text-accent font-semibold">~7,300 tokens</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
        <p class="text-dim text-sm mt-4">
          Full project analysis — discover, screenshot, interact, and report — for under 7,500 tokens. That's less than reading a single large file.
        </p>

        <!-- Session flow -->
        <div class="mt-8">
          <h3 class="text-xl font-semibold mb-4 text-ink">Session Flow</h3>
          <div class="relative rounded-xl bg-surface overflow-hidden" style="border:1px solid var(--line-2)">
            <div class="corner-tr"></div><div class="corner-bl"></div>
            <div class="flex items-center justify-between px-4 py-2.5" style="border-bottom:1px solid var(--line-2)">
              <span class="mono-label" style="color:var(--ink-faint)">composeproof session</span>
              <span class="mono-label" style="color:var(--ok)">● 7 calls</span>
            </div>
            <div class="p-5 font-mono text-xs leading-relaxed">
              <div class="text-faint"># 7 tool calls. Full project story.</div>
              <div class="mt-2"><span class="text-accent">→</span> <span class="text-ink">insights</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">list_previews</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">take_device_screenshot</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">device_interact</span> <span class="text-dim">swipe drag</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">take_device_screenshot</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">get_context</span> <span class="text-dim">scope=structure</span></div>
              <div class="mt-1"><span class="text-accent">→</span> <span class="text-ink">generate_report</span></div>
              <div class="mt-3" style="color:var(--ok)">✓ Report saved — 42 KB, score 72/100</div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-faint italic">
        This isn't a mock — this is a real session captured from Claude Code + ComposeProof.
      </p>
    </div>
  </div>
</section>
