---
interface Demo {
  title: string;
  description: string;
  videoUrl: string;
  step: number;
}

const demos: Demo[] = [
  {
    step: 1,
    title: 'Build, deploy & launch',
    description: 'AI runs preflight to detect the device, picks the right Gradle variant, builds, installs, and launches — all from a single natural language prompt.',
    videoUrl: '/demos/01-build-deploy.mp4',
  },
  {
    step: 2,
    title: 'AI discovers the interaction model',
    description: 'The FAB tap fails, so the AI reads source code, discovers the FAB opens a bottom sheet sticker tray, and switches strategy. Every action auto-screenshots.',
    videoUrl: '/demos/02-interaction-discovery.mp4',
  },
  {
    step: 3,
    title: 'Drag testing with coordinate recalculation',
    description: 'ADB swipe doesn\'t trigger Compose gestures. The AI switches to raw touch events, detects resolution mismatch, recalculates coordinates, and successfully drags stickers.',
    videoUrl: '/demos/03-drag-testing.mp4',
  },
  {
    step: 4,
    title: 'Results & persistent screenshots',
    description: 'AI produces a structured test report (3/3 pass), notes z-ordering and animations. Every screenshot from the session is saved to disk for human review.',
    videoUrl: '/demos/04-results.mp4',
  },
];

const fullSessionUrl = '/demos/full-session.mp4';
---

<section class="py-20 lg:py-28" id="demos">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="text-center mb-6">
      <div class="mono-label mb-4">recorded sessions</div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-ink">
        Watch the <span class="marker-static">demo videos</span>
      </h2>
      <p class="text-lg text-dim max-w-2xl mx-auto">
        One prompt, zero human intervention. AI builds the app, discovers UI patterns, tests interactions, and reports results.
      </p>
    </div>

    <p class="text-center text-sm text-faint mb-12">
      Recorded on a Pixel 9 Pro Fold with <a href="https://github.com/aldefy/StickerExplode" class="text-accent hover:underline" target="_blank" rel="noopener">StickerExplode</a> demo app.
    </p>

    <div class="grid md:grid-cols-2 gap-8" data-reveal-group>
      {demos.map((demo) => (
        <div class="rounded-xl bg-surface lift overflow-hidden" style="border:1px solid var(--line-2)">
          <div class="aspect-video bg-page relative">
            <video
              class="w-full h-full object-contain"
              controls
              preload="metadata"
              playsinline
              poster={demo.videoUrl.replace('.mp4', '.jpg')}
            >
              <source src={demo.videoUrl} type="video/mp4" />
              Your browser does not support video playback.
            </video>
          </div>
          <div class="p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-sm font-mono text-accent" aria-hidden="true">0{demo.step}</span>
              <h3 class="text-lg font-semibold text-ink">{demo.title}</h3>
            </div>
            <p class="text-sm text-dim">{demo.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Full session -->
    <div class="mt-10 rounded-xl bg-surface lift overflow-hidden" style="border:1px solid var(--line-2)">
      <div class="aspect-video bg-page">
        <video
          class="w-full h-full object-contain"
          controls
          preload="metadata"
          playsinline
          poster="/demos/full-session.jpg"
        >
          <source src={fullSessionUrl} type="video/mp4" />
          Your browser does not support video playback.
        </video>
      </div>
      <div class="p-5 text-center">
        <h3 class="text-lg font-semibold mb-1 text-ink">Full uncut session</h3>
        <p class="text-sm text-dim">6 minutes — from prompt to test report, no edits.</p>
      </div>
    </div>
  </div>
</section>
