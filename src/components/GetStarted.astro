---
---

<section class="py-20 lg:py-28" id="get-started">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">

    <!-- Pro demand block — shown first -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="mono-label mb-4">ComposeProof Pro</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-4">
        The full loop. <span class="marker-static">Nothing held back.</span>
      </h2>
      <p class="text-lg text-dim max-w-2xl mx-auto font-light">
        Free gives your AI eyes. Pro gives it a brain — code intelligence, embedded agent, live app internals, and deep Compose inspection.
      </p>
    </div>

    <!-- Pro feature grid — 3 columns -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16" data-reveal-group>
      <div class="rounded-xl bg-surface p-6 lift relative" style="border:1px solid var(--line-2)">
        <div class="corner-tr"></div><div class="corner-bl"></div>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-4" style="background:color-mix(in srgb,var(--accent) 12%,transparent)">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <h3 class="font-semibold text-ink mb-2">Embedded Agent</h3>
        <p class="text-sm text-dim leading-relaxed">In-app SDK gives your AI direct access to permissions, lifecycle, navigation, DataStore, and coroutines — from inside the process.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">inspect_permissions</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">simulate_process_death</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">inspect_navigation</span>
        </div>
      </div>

      <div class="rounded-xl bg-surface p-6 lift relative" style="border:1px solid var(--line-2)">
        <div class="corner-tr"></div><div class="corner-bl"></div>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-4" style="background:color-mix(in srgb,var(--accent) 12%,transparent)">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="font-semibold text-ink mb-2">Code Intelligence</h3>
        <p class="text-sm text-dim leading-relaxed">Kartograph integration — tree-sitter AST + semantic search so your AI understands your codebase structure, not just file contents.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">semantic_search</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">karto_query</span>
        </div>
      </div>

      <div class="rounded-xl bg-surface p-6 lift relative" style="border:1px solid var(--line-2)">
        <div class="corner-tr"></div><div class="corner-bl"></div>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-4" style="background:color-mix(in srgb,var(--accent) 12%,transparent)">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="font-semibold text-ink mb-2">Compose Intelligence</h3>
        <p class="text-sm text-dim leading-relaxed">Recomposition tracking, ViewModel state inspection, lazy list profiling, and design token validation — all exposed as MCP tools.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">track_recompositions</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded text-accent" style="background:color-mix(in srgb,var(--accent) 10%,transparent)">inspect_viewmodel_state</span>
        </div>
      </div>
    </div>

    <!-- Pricing — Pro first, Free below -->
    <div class="max-w-3xl mx-auto">
      <div class="grid sm:grid-cols-2 gap-6 text-left">

        <!-- Pro — featured -->
        <div class="rounded-xl bg-surface p-6 relative lift" style="border:1px solid var(--accent)">
          <div class="corner-tr"></div><div class="corner-bl"></div>
          <div class="absolute -top-3 right-4 px-2.5 py-0.5 rounded-full text-xs font-mono font-semibold" style="background:var(--accent);color:#111">Pro</div>
          <div class="mono-label mb-2">Pro</div>
          <div class="text-3xl font-mono font-bold text-ink mb-1" id="pro-price">
            <span class="text-xl font-normal text-dim">&#8377;</span>499<span class="text-sm font-normal text-faint">/mo</span>
          </div>
          <div class="text-xs text-dim mb-5">
            <span id="pro-price-note">Cancel anytime</span>
            <span class="mx-1 text-faint">·</span>
            <button id="toggle-currency" class="text-accent hover:underline">Show in USD</button>
          </div>
          <ul class="space-y-2 text-sm text-dim mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Everything in Free
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Code Intelligence — Kartograph (2 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Compose Intelligence (5 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Embedded Agent (11 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Pro Prompts (3 intelligence prompts)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Companion app + session screenshots
            </li>
          </ul>
          <!-- Primary: CLI activate (device-bound install in one command) -->
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-md bg-page font-mono text-sm mb-2" style="border:1px solid var(--accent)">
            <span class="text-faint select-none">$</span>
            <span class="text-ink flex-1 text-left whitespace-nowrap overflow-x-auto">npx composeproof activate</span>
            <button id="pro-copy-btn" class="shrink-0 text-faint hover:text-accent transition-colors" title="Copy" aria-label="Copy activate command">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </button>
          </div>
          <p class="text-center text-xs text-dim mb-2">Opens GitHub sign-in + secure Razorpay checkout, binds Pro to this device.</p>
          <a href="https://composeproof-activation.aditlal90.workers.dev/auth/github" class="block text-center text-xs text-accent hover:underline">
            or subscribe from your browser →
          </a>
        </div>

        <!-- Free — secondary -->
        <div class="rounded-xl bg-surface p-6 lift" style="border:1px solid var(--line-2)">
          <div class="mono-label mb-2" style="color:var(--ink-faint)">Free</div>
          <div class="text-3xl font-mono font-bold mb-1 text-ink">Free</div>
          <div class="text-xs text-faint mb-5">Always free, no card required</div>
          <ul class="space-y-2 text-sm text-dim mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Headless rendering + screenshots
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Golden diffing + visual regression
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              Device interaction + inspection
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              HTML reports + 8 expert prompts
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">&#10003;</span>
              21 MCP tools
            </li>
          </ul>

          <!-- Install command -->
          <div class="rounded-lg overflow-hidden" style="border:1px solid var(--line-2)">
            <div class="flex items-center gap-2 px-3 py-2" style="border-bottom:1px solid var(--line-2);background:var(--bg-2)">
              <span class="text-xs text-faint font-mono">terminal</span>
            </div>
            <div class="px-4 py-3 font-mono flex items-center gap-3" style="background:var(--bg-2)">
              <span class="text-faint select-none">$</span>
              <span class="text-sm text-ink" id="install-cmd">npx composeproof</span>
              <button
                id="copy-btn"
                class="ml-auto text-faint hover:text-accent transition-colors"
                title="Copy"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  function wireCopy(id, text) {
    const btn = document.getElementById(id);
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(text);
      const html = btn.innerHTML;
      btn.innerHTML = '<span class="text-accent text-xs font-mono">✓</span>';
      setTimeout(() => { btn.innerHTML = html; }, 1500);
    });
  }
  wireCopy('copy-btn', 'npx composeproof');
  wireCopy('pro-copy-btn', 'npx composeproof activate');

  // PPP currency toggle
  const priceEl = document.getElementById('pro-price');
  const noteEl = document.getElementById('pro-price-note');
  const toggleBtn = document.getElementById('toggle-currency');
  let showingINR = true;

  try {
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const isIndia = tz === 'Asia/Kolkata' || tz === 'Asia/Calcutta' || navigator.language?.startsWith('hi');
    if (!isIndia) {
      showingINR = false;
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-dim">$</span>9<span class="text-sm font-normal text-faint">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in INR';
    }
  } catch (_) {}

  toggleBtn?.addEventListener('click', () => {
    if (showingINR) {
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-dim">$</span>9<span class="text-sm font-normal text-faint">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in INR';
    } else {
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-dim">₹</span>499<span class="text-sm font-normal text-faint">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in USD';
    }
    showingINR = !showingINR;
  });
</script>
