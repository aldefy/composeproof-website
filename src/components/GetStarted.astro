---
---

<section class="py-20 lg:py-28" id="get-started">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">

    <!-- Pro demand block — shown first -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="font-mono text-xs text-brand-purple uppercase tracking-widest mb-4">ComposeProof Pro</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
        The full loop. <span class="gradient-text">Nothing held back.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto font-light">
        Free gives your AI eyes. Pro gives it a brain — code intelligence, embedded agent, live app internals, and deep Compose inspection.
      </p>
    </div>

    <!-- Pro feature grid — 3 columns -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16">
      <div class="rounded-xl border border-brand-purple/20 bg-brand-card/20 p-6">
        <div class="w-8 h-8 rounded-lg bg-brand-purple/10 flex items-center justify-center mb-4">
          <svg class="w-4 h-4 text-brand-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">Embedded Agent</h3>
        <p class="text-sm text-slate-400 leading-relaxed">In-app SDK gives your AI direct access to permissions, lifecycle, navigation, DataStore, and coroutines — from inside the process.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-brand-purple/10 text-brand-purple/70">inspect_permissions</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-brand-purple/10 text-brand-purple/70">simulate_process_death</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-brand-purple/10 text-brand-purple/70">inspect_navigation</span>
        </div>
      </div>

      <div class="rounded-xl border border-brand-cyan/20 bg-brand-card/20 p-6">
        <div class="w-8 h-8 rounded-lg bg-brand-cyan/10 flex items-center justify-center mb-4">
          <svg class="w-4 h-4 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">Code Intelligence</h3>
        <p class="text-sm text-slate-400 leading-relaxed">Kartograph integration — tree-sitter AST + semantic search so your AI understands your codebase structure, not just file contents.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-brand-cyan/10 text-brand-cyan/70">semantic_search</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-brand-cyan/10 text-brand-cyan/70">karto_query</span>
        </div>
      </div>

      <div class="rounded-xl border border-yellow-500/20 bg-brand-card/20 p-6">
        <div class="w-8 h-8 rounded-lg bg-yellow-500/10 flex items-center justify-center mb-4">
          <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">Compose Intelligence</h3>
        <p class="text-sm text-slate-400 leading-relaxed">Recomposition tracking, ViewModel state inspection, lazy list profiling, and design token validation — all exposed as MCP tools.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-yellow-500/10 text-yellow-400/70">track_recompositions</span>
          <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-yellow-500/10 text-yellow-400/70">inspect_viewmodel_state</span>
        </div>
      </div>
    </div>

    <!-- Pricing — Pro first, Free below -->
    <div class="max-w-3xl mx-auto">
      <div class="grid sm:grid-cols-2 gap-6 text-left">

        <!-- Pro — featured -->
        <div class="rounded-xl border border-brand-purple/40 bg-brand-card/40 p-6 relative glow-purple">
          <div class="absolute -top-3 right-4 px-2.5 py-0.5 rounded-full bg-brand-purple text-xs font-semibold text-white">Pro</div>
          <div class="text-sm font-medium text-brand-purple uppercase tracking-wider mb-2">Pro</div>
          <div class="text-3xl font-bold mb-1" id="pro-price">
            <span class="text-xl font-normal text-slate-400">&#8377;</span>499<span class="text-sm font-normal text-slate-500">/mo</span>
          </div>
          <div class="text-xs text-slate-500 mb-5">
            <span id="pro-price-note">Cancel anytime</span>
            <span class="mx-1 text-slate-600">·</span>
            <button id="toggle-currency" class="text-brand-purple hover:underline">Show in USD</button>
          </div>
          <ul class="space-y-2 text-sm text-slate-400 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Everything in Free
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Code Intelligence — Kartograph (2 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Compose Intelligence (5 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Embedded Agent (11 tools)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Pro Prompts (3 intelligence prompts)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-purple mt-0.5">&#10003;</span>
              Companion app + session screenshots
            </li>
          </ul>
          <a
            href="https://composeproof-activation.aditlal90.workers.dev/auth/github"
            class="block w-full text-center px-4 py-2.5 rounded-lg bg-brand-purple font-semibold text-white hover:bg-brand-purple-deep transition-all duration-200 hover:shadow-[0_0_20px_rgba(123,97,255,0.4)] text-sm"
          >
            Subscribe with GitHub
          </a>
          <p class="text-center text-xs text-slate-500 mt-2">
            or activate from your terminal:
            <a href="/activate" class="text-brand-purple hover:underline">CLI setup</a>
          </p>
        </div>

        <!-- Free — secondary -->
        <div class="rounded-xl border border-brand-border bg-brand-card/20 p-6">
          <div class="text-sm font-medium text-slate-400 uppercase tracking-wider mb-2">Free</div>
          <div class="text-3xl font-bold mb-1 text-slate-300">Free</div>
          <div class="text-xs text-slate-600 mb-5">Always free, no card required</div>
          <ul class="space-y-2 text-sm text-slate-400 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-brand-teal mt-0.5">&#10003;</span>
              Headless rendering + screenshots
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-teal mt-0.5">&#10003;</span>
              Golden diffing + visual regression
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-teal mt-0.5">&#10003;</span>
              Device interaction + inspection
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-teal mt-0.5">&#10003;</span>
              HTML reports + 8 expert prompts
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-teal mt-0.5">&#10003;</span>
              21 MCP tools
            </li>
          </ul>

          <!-- Install command -->
          <div class="rounded-lg border border-brand-border bg-brand-darker overflow-hidden">
            <div class="flex items-center gap-2 px-3 py-2 border-b border-brand-border bg-brand-card/30">
              <span class="text-xs text-slate-600 font-mono">terminal</span>
            </div>
            <div class="px-4 py-3 font-mono flex items-center gap-3">
              <span class="text-slate-600 select-none">$</span>
              <span class="text-sm text-slate-200" id="install-cmd">npx composeproof</span>
              <button
                id="copy-btn"
                class="ml-auto text-slate-600 hover:text-brand-cyan transition-colors"
                title="Copy"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npx composeproof');
    const btn = document.getElementById('copy-btn');
    if (btn) {
      btn.innerHTML = '<span class="text-brand-cyan text-xs font-mono">✓</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
      }, 1500);
    }
  });

  // PPP currency toggle
  const priceEl = document.getElementById('pro-price');
  const noteEl = document.getElementById('pro-price-note');
  const toggleBtn = document.getElementById('toggle-currency');
  let showingINR = true;

  try {
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const isIndia = tz === 'Asia/Kolkata' || tz === 'Asia/Calcutta' || navigator.language?.startsWith('hi');
    if (!isIndia) {
      showingINR = false;
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-slate-400">$</span>9<span class="text-sm font-normal text-slate-500">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in INR';
    }
  } catch (_) {}

  toggleBtn?.addEventListener('click', () => {
    if (showingINR) {
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-slate-400">$</span>9<span class="text-sm font-normal text-slate-500">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in INR';
    } else {
      if (priceEl) priceEl.innerHTML = '<span class="text-xl font-normal text-slate-400">\u20B9</span>499<span class="text-sm font-normal text-slate-500">/mo</span>';
      if (toggleBtn) toggleBtn.textContent = 'Show in USD';
    }
    showingINR = !showingINR;
  });
</script>
