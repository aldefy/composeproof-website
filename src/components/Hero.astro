---
// Render state thumbnails — actual representative UI content per edge case
const renderStates = [
  {
    label: 'empty',
    pass: true,
    delay: '0.1s',
    bg: 'bg-[#0f111a]',
    content: `
      <div class="flex flex-col items-center justify-center h-full gap-1 px-1">
        <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
        <div class="w-6 h-0.5 bg-slate-700 rounded mt-0.5"></div>
        <div class="w-4 h-0.5 bg-slate-800 rounded"></div>
      </div>
    `,
  },
  {
    label: 'error',
    pass: true,
    delay: '0.2s',
    bg: 'bg-[#120b0b]',
    content: `
      <div class="flex flex-col items-center justify-center h-full gap-1">
        <svg class="w-4 h-4 text-red-500/80" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <div class="w-7 h-1 bg-red-900/60 rounded mt-1"></div>
        <div class="w-5 h-0.5 bg-red-900/40 rounded mt-0.5"></div>
        <div class="w-4 h-2.5 bg-red-800/30 rounded-sm mt-1"></div>
      </div>
    `,
  },
  {
    label: 'loading',
    pass: true,
    delay: '0.3s',
    bg: 'bg-[#0c0e18]',
    content: `
      <div class="flex flex-col gap-1.5 px-2 pt-3 h-full">
        <div class="w-full h-2 bg-slate-700/50 rounded animate-pulse"></div>
        <div class="w-4/5 h-2 bg-slate-700/40 rounded animate-pulse" style="animation-delay:0.1s"></div>
        <div class="w-full h-2 bg-slate-700/50 rounded animate-pulse" style="animation-delay:0.2s"></div>
        <div class="w-3/5 h-2 bg-slate-700/40 rounded animate-pulse" style="animation-delay:0.15s"></div>
        <div class="w-full h-2 bg-slate-700/30 rounded animate-pulse" style="animation-delay:0.3s"></div>
      </div>
    `,
  },
  {
    label: 'overflow',
    pass: false,
    delay: '0.15s',
    bg: 'bg-[#120e06]',
    content: `
      <div class="flex flex-col gap-1 px-1 pt-2 h-full overflow-hidden">
        <div class="w-full h-1.5 bg-amber-700/40 rounded"></div>
        <div class="text-[6px] font-mono text-amber-400/80 leading-tight overflow-hidden whitespace-nowrap">VeryLongProductNameThatOverflows</div>
        <div class="w-full h-1.5 bg-amber-700/30 rounded"></div>
        <div class="flex gap-0.5 mt-0.5">
          <div class="w-3 h-3 bg-amber-700/40 rounded-sm"></div>
          <div class="flex-1 h-3 bg-amber-700/30 rounded-sm overflow-hidden">
            <div class="h-full w-[140%] bg-amber-800/30"></div>
          </div>
        </div>
        <div class="mt-auto mb-1 flex items-center gap-1">
          <svg class="w-2.5 h-2.5 text-amber-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <span class="text-[5px] text-amber-400 font-mono">overflow</span>
        </div>
      </div>
    `,
  },
  {
    label: 'RTL',
    pass: true,
    delay: '0.25s',
    bg: 'bg-[#0c0f18]',
    content: `
      <div class="flex flex-col gap-1.5 px-1.5 pt-3 h-full" dir="rtl">
        <div class="w-full h-1.5 bg-brand-purple/20 rounded"></div>
        <div class="flex gap-1 items-center justify-end">
          <div class="w-4 h-1 bg-slate-600/50 rounded"></div>
          <div class="w-2.5 h-2.5 rounded bg-brand-purple/30"></div>
        </div>
        <div class="w-4/5 h-1 bg-slate-700/40 rounded"></div>
        <div class="w-full h-1 bg-slate-700/30 rounded"></div>
        <div class="mt-auto mb-1 self-end text-[5px] font-mono text-brand-purple/60">✓ RTL</div>
      </div>
    `,
  },
  {
    label: '500 items',
    pass: true,
    delay: '0.35s',
    bg: 'bg-[#090c14]',
    content: `
      <div class="flex flex-col gap-0.5 px-1 pt-2 h-full overflow-hidden">
        ${Array(9).fill(0).map((_, i) => `
          <div class="flex gap-1 items-center shrink-0">
            <div class="w-2 h-2 rounded-sm bg-slate-700/60 shrink-0"></div>
            <div class="h-1 bg-slate-700/40 rounded flex-1" style="width:${60 + (i * 7) % 35}%"></div>
          </div>
        `).join('')}
        <div class="text-[5px] font-mono text-slate-600 mt-0.5">…500</div>
      </div>
    `,
  },
  {
    label: 'no network',
    pass: true,
    delay: '0.4s',
    bg: 'bg-[#0c0c14]',
    content: `
      <div class="flex flex-col items-center justify-center h-full gap-1">
        <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728M5.636 5.636a9 9 0 000 12.728M9 10a3 3 0 014.5-2.598M15 10a3 3 0 00-3-3m0 6a1 1 0 100-2 1 1 0 000 2z"/><line x1="3" y1="3" x2="21" y2="21" stroke-linecap="round" stroke-width="1.5"/></svg>
        <div class="w-8 h-0.5 bg-slate-700 rounded mt-0.5"></div>
        <div class="w-5 h-2 bg-slate-800/80 rounded-sm mt-1 flex items-center justify-center">
          <div class="w-3 h-0.5 bg-slate-600 rounded"></div>
        </div>
      </div>
    `,
  },
  {
    label: 'offline',
    pass: true,
    delay: '0.45s',
    bg: 'bg-[#0b0c14]',
    content: `
      <div class="flex flex-col items-center justify-center h-full gap-1">
        <svg class="w-5 h-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/><line x1="3" y1="3" x2="21" y2="21" stroke-linecap="round" stroke-width="1.5"/></svg>
        <div class="text-[6px] font-mono text-slate-600 mt-0.5">cached</div>
        <div class="w-7 h-1.5 bg-brand-cyan/20 rounded-full mt-0.5 flex items-center px-0.5">
          <div class="w-1.5 h-1 bg-brand-cyan/60 rounded-full"></div>
        </div>
      </div>
    `,
  },
];
---

<section class="relative overflow-hidden pt-24 pb-0">
  <!-- Dot grid background — precision instrument -->
  <div class="absolute inset-0 dot-grid-fine opacity-50 pointer-events-none"></div>

  <!-- Radial purple glow from top center -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(123,97,255,0.1),transparent)] pointer-events-none"></div>

  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-16 items-center">

      <!-- LEFT: Copy -->
      <div class="pt-6">

        <!-- Status pill -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-border bg-brand-card/60 text-sm text-slate-400 mb-10 font-mono">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-cyan animate-pulse"></span>
          v1.2 live
          <span class="text-brand-border mx-1">|</span>
          <img src="https://img.shields.io/npm/dt/composeproof?style=flat&color=7B61FF&label=installs&labelColor=0c0e16" alt="installs" class="h-4" loading="lazy" />
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold tracking-tight mb-6">
          <span class="block text-[1.6rem] sm:text-[2rem] lg:text-[2.2rem] text-slate-400 leading-snug mb-3">Tired of your AI writing<br class="hidden sm:block"/> code it can't see?</span>
          <span class="block text-[3.4rem] sm:text-[4.2rem] lg:text-[4.8rem] leading-[1.1] pb-2 text-white">Yeah, so<br/>were <span class="gradient-text">we.</span></span>
        </h1>

        <p class="text-[1.05rem] text-slate-400 mb-8 max-w-md leading-relaxed font-light">
          ComposeProof is an MCP server that gives your AI coding assistant X-ray vision into your <span class="text-slate-200">running</span> Compose app — read the live UI tree, Compose &amp; ViewModel state, navigation, and recomposition. Screenshots are just one of the things it can see.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 items-center mb-8">
          <a
            href="#get-started"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-brand-purple font-semibold text-white hover:bg-brand-purple-deep transition-all duration-200 hover:shadow-[0_0_28px_rgba(123,97,255,0.45)] text-[0.95rem]"
          >
            Get Started Free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href="https://docs.composeproof.dev"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-brand-border-bright text-slate-300 hover:bg-brand-card/60 transition-colors text-[0.95rem]"
          >
            Docs
          </a>
        </div>

        <!-- Install command -->
        <div class="inline-flex items-center gap-3 px-4 py-2.5 rounded-lg bg-brand-darker border border-brand-border font-mono text-sm mb-10">
          <span class="text-slate-600 select-none">$</span>
          <span class="text-slate-200">npx composeproof</span>
          <button id="hero-copy-btn" class="ml-1 text-slate-600 hover:text-brand-cyan transition-colors" title="Copy">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </button>
        </div>

        <!-- Client logos -->
        <div class="border-t border-brand-border/50 pt-6">
          <p class="text-xs font-mono text-slate-600 uppercase tracking-widest mb-3">Works with any MCP client</p>
          <div class="flex flex-wrap items-center gap-2">
            {['Claude Code', 'Cursor', 'Gemini CLI', 'Android Studio'].map(c => (
              <span class="px-3 py-1 rounded border border-brand-border bg-brand-card/40 text-xs text-slate-500 font-mono">{c}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT: Real device screenshots -->
      <div class="relative lg:mt-4 flex justify-center items-end h-[580px]">

        <!-- Glow behind phones -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_60%,rgba(123,97,255,0.12),transparent)] pointer-events-none"></div>

        <!-- Phone 1: canvas (main, center) -->
        <div class="relative z-10 w-[220px] rounded-[2rem] border-2 border-white/10 overflow-hidden shadow-2xl" style="box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 40px rgba(123,97,255,0.15);">
          <!-- Notch bar -->
          <div class="absolute top-0 left-0 right-0 h-6 bg-black/60 z-10 flex items-center justify-center">
            <div class="w-16 h-1 bg-white/20 rounded-full"></div>
          </div>
          <img
            src="/renders/screen_canvas.png"
            alt="StickerExplode canvas — captured by ComposeProof"
            class="w-full object-cover"
            style="height: 480px; object-position: top;"
            loading="eager"
          />
          <!-- ComposeProof badge -->
          <div class="absolute bottom-3 left-0 right-0 flex justify-center z-10">
            <span class="font-mono text-[9px] px-2 py-0.5 rounded-full bg-brand-darker/90 border border-brand-border text-brand-cyan">captured by composeproof</span>
          </div>
        </div>

        <!-- Phone 2: sticker tray (offset right, slightly behind) -->
        <div class="absolute right-4 bottom-0 w-[180px] rounded-[1.8rem] border-2 border-white/8 overflow-hidden shadow-xl z-20" style="box-shadow: 0 24px 60px rgba(0,0,0,0.5);">
          <div class="absolute top-0 left-0 right-0 h-5 bg-black/60 z-10 flex items-center justify-center">
            <div class="w-12 h-1 bg-white/20 rounded-full"></div>
          </div>
          <img
            src="/renders/screen_tray.png"
            alt="Add Sticker tray — captured by ComposeProof"
            class="w-full object-cover"
            style="height: 390px; object-position: top;"
            loading="eager"
          />
        </div>

      </div>

    </div>
  </div>

  <!-- Section fade -->
  <div class="h-20 bg-gradient-to-b from-transparent to-brand-dark mt-8"></div>
</section>

<script>
  document.getElementById('hero-copy-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npx composeproof');
    const btn = document.getElementById('hero-copy-btn');
    if (btn) {
      btn.innerHTML = '<span class="text-brand-cyan text-xs font-mono">✓</span>';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
      }, 1500);
    }
  });
</script>
