---
---

<section class="relative overflow-hidden pt-28 pb-16 lg:pt-36 lg:pb-24">
  <!-- faint instrument grid -->
  <div class="absolute inset-0 inst-grid opacity-70 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-x-0 top-0 h-px" style="background:var(--line-2)"></div>

  <div class="relative max-w-5xl mx-auto px-6 text-center">

    <!-- eyebrow -->
    <div class="hero-rise inline-flex items-center gap-2.5 mono-label mb-7" style="--hero-delay:40ms">
      <span class="inline-block w-1.5 h-1.5 rounded-full" style="background:var(--accent)"></span>
      MCP server · Compose + Android · v1.3
    </div>

    <!-- headline -->
    <h1 class="hero-rise font-display font-extrabold text-ink leading-[0.98] tracking-tight text-[2.7rem] sm:text-[3.6rem] lg:text-[4.4rem] mb-6" style="--hero-delay:120ms">
      Your AI writes Compose<br class="hidden sm:block" /> it can’t see.
      <span class="block mt-2">Give it <span class="marker">X-ray vision</span>.</span>
    </h1>

    <!-- subcopy -->
    <p class="hero-rise text-[1.05rem] sm:text-[1.15rem] text-dim max-w-2xl mx-auto leading-relaxed mb-9" style="--hero-delay:220ms">
      ComposeProof is an MCP server that reads your <span class="text-ink font-medium">running</span> app’s internals —
      the live UI tree, Compose &amp; ViewModel state, navigation, and recomposition.
      Screenshots are just one signal it can read.
    </p>

    <!-- CTAs -->
    <div class="hero-rise flex flex-wrap items-center justify-center gap-3 mb-6" style="--hero-delay:300ms">
      <a href="#get-started" class="inline-flex items-center gap-2 px-6 py-3 rounded-md font-mono font-semibold text-sm transition-transform hover:-translate-y-0.5" style="background:var(--accent);color:#111">
        Get started free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href="https://docs.composeproof.dev" class="inline-flex items-center gap-2 px-6 py-3 rounded-md text-sm text-ink transition-colors hover:bg-surface" style="border:1px solid var(--line-2)">
        Read the docs
      </a>
    </div>

    <!-- install -->
    <div class="hero-rise inline-flex items-center gap-3 px-4 py-2.5 rounded-md bg-surface font-mono text-sm mb-2" style="--hero-delay:360ms;border:1px solid var(--line-2)">
      <span class="text-faint select-none">$</span>
      <span class="text-ink">npx composeproof</span>
      <button id="hero-copy-btn" class="ml-1 text-faint hover:text-accent transition-colors" title="Copy" aria-label="Copy install command">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      </button>
    </div>
    <p class="hero-rise mono-label text-faint" style="--hero-delay:400ms;color:var(--ink-faint)">works with claude code · cursor · gemini cli</p>

    <!-- ============ INSPECTOR CENTERPIECE ============ -->
    <div class="hero-rise relative mt-16 mx-auto max-w-4xl" style="--hero-delay:460ms">
      <div class="grid grid-cols-1 md:grid-cols-[0.82fr_1.18fr] items-stretch gap-4 md:gap-5">

        <!-- LEFT: the running app (input) -->
        <div class="relative rounded-xl p-5 bg-surface scanlines" style="border:1px solid var(--line-2)">
          <div class="corner-tr"></div><div class="corner-bl"></div>
          <div class="flex items-center justify-between mb-4">
            <span class="mono-label" style="color:var(--ink-faint)">running app</span>
            <span class="mono-label" style="color:var(--ink-faint);font-size:.6rem">StickersScreen</span>
          </div>
          <!-- app frame -->
          <div class="relative rounded-lg mx-auto px-3.5 py-3.5 text-left" style="max-width:200px;border:1px solid var(--line-2);background:var(--bg-2)">
            <!-- highlighted node: the title, with a clean label tab to the right -->
            <div class="relative inline-block mb-3">
              <span class="text-ink font-semibold text-[13px] px-1 py-0.5 rounded-sm" style="outline:1.5px solid var(--accent);outline-offset:1px">Add Sticker</span>
              <span class="absolute left-full ml-2 top-1/2 -translate-y-1/2 mono-label whitespace-nowrap" style="font-size:.52rem;letter-spacing:.06em;color:var(--accent)">◂ Text</span>
            </div>
            <div class="flex gap-1.5 mb-3">
              <span class="text-[9px] px-2 py-0.5 rounded-full text-dim" style="border:1px solid var(--line-2)">★ Fav</span>
              <span class="text-[9px] px-2 py-0.5 rounded-full text-dim" style="border:1px solid var(--line-2)">Recent</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
              {Array(6).fill(0).map(() => (
                <div class="aspect-square rounded" style="background:var(--line-2)"></div>
              ))}
            </div>
          </div>
          <div class="text-center mono-label mt-4" style="font-size:.52rem;color:var(--ink-faint)">rendered headlessly · no device</div>
        </div>

        <!-- RIGHT: what the AI reads (output) -->
        <div class="relative rounded-xl p-5 bg-surface text-left scanlines" style="border:1px solid var(--line-2)">
          <div class="corner-tr"></div><div class="corner-bl"></div>
          <div class="flex items-center justify-between mb-3">
            <span class="mono-label">inspect · ui_tree</span>
            <span class="mono-label" style="color:var(--ok)">● read 42ms</span>
          </div>
          <pre class="font-mono text-[12.5px] leading-[1.75] text-dim overflow-x-auto" style="margin:0"><span class="text-ink">Column</span>
 └ <span class="text-ink">Row</span>
     ├ Icon <span class="text-accent">★</span>
     └ <span class="text-ink">Text</span> <span class="text-accent">"Add Sticker"</span>
 └ <span class="text-ink">LazyVerticalGrid</span> <span style="color:var(--ink-faint)">· items=6</span>

<span style="color:var(--ink-faint)">state ─────────────────────</span>
 count <span class="text-accent">3</span>   loading <span class="text-accent">false</span>
 route <span class="text-accent">/stickers</span>

<span style="color:var(--ink-faint)">checks ────────────────────</span>
 a11y <span style="color:var(--ok)">ok</span>   recompose <span style="color:var(--ok)">1×</span>   golden <span style="color:var(--ok)">ok</span><span class="cursor-blink text-accent">▋</span></pre>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // draw the amber marker underline shortly after the headline settles
  setTimeout(() => {
    document.querySelectorAll('.marker').forEach((m) => m.classList.add('drawn'));
  }, 650);

  document.getElementById('hero-copy-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npx composeproof');
    const btn = document.getElementById('hero-copy-btn');
    if (btn) {
      const html = btn.innerHTML;
      btn.innerHTML = '<span class="text-accent text-xs font-mono">✓</span>';
      setTimeout(() => { btn.innerHTML = html; }, 1500);
    }
  });
</script>
