---
const steps = [
  {
    number: '01',
    title: 'Run the setup wizard',
    description: 'One command. Installs the binary, picks your AI agents (Claude Code, Gemini CLI, Cursor), configures MCP, and optionally installs the Compose UI skill.',
    code: 'npx composeproof',
  },
  {
    number: '02',
    title: 'AI builds and renders',
    description: 'Your AI assistant writes code, renders previews headlessly, generates edge-case tests, and iterates on UI autonomously.',
    code: 'You: "build the order screen"\nAI:  writes code → renders 12 edge cases → PASS ✓',
  },
  {
    number: '03',
    title: 'Verify end-to-end',
    description: 'Mock backend APIs on a real device, screenshot every state, and confirm the full loop works. No Postman, no manual QA.',
    code: 'AI: mock_api GET /orders → empty, error, 500 items\n    take_screenshot × 3 states\n    ✓ all states render correctly',
  },
];
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="text-center mb-16">
      <p class="mono-label mb-4">How it works</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-ink">
        Up and running in <span class="marker-static">3 steps</span>
      </h2>
      <p class="text-lg text-dim max-w-2xl mx-auto">
        Zero-install architecture. No changes to your project's build files.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-10" data-reveal-group>
      {steps.map((step) => (
        <div class="relative">
          <div class="text-7xl font-bold text-accent mb-4 font-mono" aria-hidden="true">{step.number}</div>
          <h3 class="text-2xl font-semibold mb-3 text-ink">{step.title}</h3>
          <p class="text-dim mb-5">{step.description}</p>
          <div class="bg-surface rounded-lg p-5 font-mono text-sm" style="border:1px solid var(--line-2)">
            <pre class="text-ink whitespace-pre-wrap">{step.code}</pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
