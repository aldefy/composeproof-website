---
---

<nav class="fixed top-0 inset-x-0 z-50 bg-page/85 backdrop-blur-md" style="border-bottom:1px solid var(--line-2)">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Wordmark -->
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-md" style="border:1.5px solid var(--outline)">
          <span class="mono-label" style="font-size:.8rem;letter-spacing:0">CP</span>
        </span>
        <span class="font-mono font-semibold text-ink tracking-tight text-[0.95rem]">composeproof</span>
      </a>

      <!-- Links -->
      <div class="flex items-center gap-1 sm:gap-1.5">
        <a href="/#tools" class="link-tick hidden sm:inline-flex px-3 py-2 text-sm text-dim hover:text-ink transition-colors">Tools</a>
        <a href="/#get-started" class="link-tick px-3 py-2 text-sm text-dim hover:text-ink transition-colors">Pricing</a>
        <a href="https://docs.composeproof.dev" class="link-tick hidden sm:inline-flex px-3 py-2 text-sm text-dim hover:text-ink transition-colors">Docs</a>
        <a href="https://github.com/aldefy/composeproof" class="link-tick hidden md:inline-flex px-3 py-2 text-sm text-dim hover:text-ink transition-colors" target="_blank" rel="noopener">GitHub</a>

        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Toggle theme" class="ml-1 inline-flex items-center justify-center w-9 h-9 rounded-md text-dim hover:text-ink transition-colors" style="border:1px solid var(--line-2)">
          <svg class="w-4 h-4 theme-sun" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2m0 16v2M2 12h2m16 0h2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg>
          <svg class="w-4 h-4 theme-moon hidden" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>

        <a
          href="/#get-started"
          class="ml-1.5 inline-flex items-center gap-1.5 px-4 py-2 rounded-md font-mono font-semibold text-sm transition-transform hover:-translate-y-0.5"
          style="background:var(--accent);color:#111;"
        >
          Get&nbsp;Pro
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    function sync() {
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      var sun = document.querySelector('.theme-sun'), moon = document.querySelector('.theme-moon');
      if (sun && moon) { sun.classList.toggle('hidden', dark); moon.classList.toggle('hidden', !dark); }
    }
    sync();
    var b = document.getElementById('theme-toggle');
    if (b) b.addEventListener('click', function () { setTimeout(sync, 0); });
  })();
</script>
