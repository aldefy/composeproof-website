---
const waves = [
  {
    number: 1,
    title: 'Headless Rendering & Verification',
    status: 'shipped',
    items: ['render', 'list_previews', 'verify', 'render_batch', 'diff', 'insights'],
  },
  {
    number: 2,
    title: 'Device Inspection & Interaction',
    status: 'shipped',
    items: ['preflight', 'inspect_ui_tree', 'device_interact', 'take_device_screenshot', 'build_and_deploy', 'get_build_status', 'get_recomposition_stats', 'get_network_logs', 'manage_proxy', 'get_feature_flags'],
  },
  {
    number: 3,
    title: 'Embedded Agent — Runtime Inspection',
    status: 'shipped',
    items: ['inspect_permissions', 'inspect_process_lifecycle', 'inspect_navigation_graph', 'inspect_datastore', 'inspect_coroutine_state', 'execute_deeplink', 'simulate_process_death'],
  },
  {
    number: 4,
    title: 'AI Skills & Session Learning',
    status: 'shipped',
    items: ['npx composeproof installer', 'compose-ui-workflow skill', 'MCP instructions', 'expert prompts (6)', 'license gating'],
  },
  {
    number: 5,
    title: 'Edge-Case Testing & API Mocking',
    status: 'shipped',
    items: ['generate_edge_cases', 'mock_api', 'composable type analysis', 'WireMock integration', 'ADB proxy orchestration', 'stale proxy safety'],
  },
  {
    number: 6,
    title: 'Multiplatform & CI',
    status: 'planned',
    items: ['CMP rendering', 'Gradle plugin', 'GitHub Action', 'HTML reports', 'SSE transport'],
  },
];
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl 2xl:max-w-[85%] mx-auto px-6">
    <div class="text-center mb-16">
      <div class="mono-label mb-4">build log</div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-ink">
        Road<span class="marker-static">map</span>
      </h2>
      <p class="text-lg text-dim max-w-2xl mx-auto">
        40 tools shipped across 5 waves. Edge-case testing & API mocking shipped. Multiplatform next.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5" data-reveal-group>
      {waves.map((wave) => (
        <div
          class="relative rounded-xl bg-surface p-5 lift"
          style={
            wave.status === 'shipped'
              ? 'border:1px solid var(--line-2)'
              : 'border:1px solid color-mix(in srgb, var(--accent) 38%, var(--line-2))'
          }
        >
          <div class="flex items-center gap-3 mb-4">
            <div
              class="w-9 h-9 rounded-lg flex items-center justify-center font-mono font-bold text-sm shrink-0"
              style={
                wave.status === 'shipped'
                  ? 'border:1px solid var(--line-2);color:var(--ok)'
                  : 'border:1px dashed var(--accent);color:var(--accent)'
              }
            >
              {wave.number}
            </div>
            <h3 class="text-[15px] font-semibold text-ink leading-tight flex-1">{wave.title}</h3>
            <span
              class="mono-label shrink-0 px-2 py-0.5 rounded-full"
              style={
                wave.status === 'shipped'
                  ? 'color:var(--ok);border:1px solid color-mix(in srgb, var(--ok) 35%, transparent)'
                  : 'color:var(--accent);border:1px solid color-mix(in srgb, var(--accent) 45%, transparent)'
              }
            >
              {wave.status === 'shipped' ? 'Shipped' : 'Planned'}
            </span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {wave.items.map((item) => (
              <code class="text-[11px] px-1.5 py-0.5 rounded bg-page text-dim font-mono" style="border:1px solid var(--line-2)">{item}</code>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
